# Copy to ".env" for local development only. Do not commit .env.
#
# DigitalOcean App Platform — database connection (pick ONE approach):
#
# 1) Bindable (recommended): on your WEB SERVICE component → Environment Variables:
#    Key: DATABASE_URL
#    Value: ${YOUR_DB_COMPONENT_NAME.DATABASE_URL}
#    Use the exact database component name from the app (e.g. db, postgres-db).
#    Scope: RUN_TIME. Wrong component name leaves this empty and breaks deploy.
#
# 2) Literal URL (encrypted): paste the full postgresql://... string as DATABASE_URL.
#
# 3) Discrete vars (if you prefer not to use a single URL):
#    POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_HOST, POSTGRES_PORT, POSTGRES_DB
#    Optional: POSTGRES_SSLMODE=require

# DATABASE_URL=postgresql://USER:PASSWORD@HOST:25060/defaultdb?sslmode=require

# DJANGO_DEBUG=True
# DJANGO_SECRET_KEY=dev-only-change-me
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

# If SSL errors with a local Postgres tunnel, try:
# DATABASE_SSL_REQUIRE=false
